# Kafka;
KAFKA_PORT_EXTERNAL=9092
KAFKA_TOPIC=wikimediaRecentchange
KAFKA_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1

# Por algum motivo o docker composer ignora o que vem depois do espaço da string, não importa como usamos as aspas;
# Para evitar de separar o local das ENVs preferi separar.
WINDOW_DURATION_NUMERIC=5
WINDOW_DURATION_UNIT=minutes
WINDOW_SLIDE_DURATION_NUMERIC=5
WINDOW_SLIDE_DURATION_UNIT=minutes

# Classificador semântico (sentence-transformers). Valor sem espaços (start.sh usa xargs).
# Ex.: all-MiniLM-L6-v2 (inglês) ou intfloat/multilingual-e5-base (multilíngue).
MODEL_NAME=intfloat/multilingual-e5-base

# Wikimedia producer;
WIKIMEDIA_URL=https://stream.wikimedia.org/v2/stream/recentchange