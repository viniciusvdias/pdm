          "rawQuery": true,
          "rawSql": "SELECT \n  date_trunc('second', timestamp) AS time,\n  sensor_id AS metric,\n  MAX(CASE WHEN status_ia_borda = 'ALERTA_INCENDIO' THEN 1 ELSE 0 END) AS value\nFROM historico_sensores\nWHERE timestamp >= NOW() - INTERVAL '5 minutes'\nGROUP BY time, sensor_id\nORDER BY time;",
