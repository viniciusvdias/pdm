# ==== Parâmetros do projeto (copie para .env e ajuste) ====
# IMPORTANTE: no formato .env do Docker Compose, comentários ficam em LINHAS
# próprias (não no fim de uma linha de valor), senão viram parte do valor.

# --- Dados ---
# Caminho (no host) do CSV usado pelo producer/baseline. Default: a amostra.
# Para o dataset completo, aponte para o CSV amplificado (ver bin/amplify.sh).
INPUT_CSV=./datasample/sample.csv.gz

# --- Flink / paralelismo ---
PARALLELISM=2
TASK_SLOTS=4
# Intervalo de checkpoint em ms (experimento de custo de checkpoint).
CHECKPOINT_MS=5000
# Garantia do sink Kafka: EXACTLY_ONCE ou AT_LEAST_ONCE.
GUARANTEE=EXACTLY_ONCE
# Out-of-orderness do watermark (ms). Deve cobrir o jitter do schema (2000ms).
WATERMARK_OOO_MS=2000
# Saldo inicial de cada conta (centavos). 500000000 = 5.000.000,00.
OPENING_BALANCE_CENTS=500000000
# Limite por transação (centavos). Débitos acima são REJECTED. 20000000 = 200.000,00.
TX_LIMIT_CENTS=20000000

# --- Producer ---
# Taxa-base de emissão (transações/segundo). 0 = o mais rápido possível.
RATE=2000
# Modo de burst: none | rate | synthetic
#   none      -> taxa constante
#   rate      -> picos aleatórios de TAXA (replay real; seguro p/ reconciliação)
#   synthetic -> rate + injeção de transações sintéticas de ALTO VALOR
BURST_MODE=rate
# Probabilidade de iniciar burst por "tick" (1s).
BURST_PROB=0.02
# Duração mínima/máxima do burst (s).
BURST_MIN_S=3
BURST_MAX_S=10
# Multiplicador mínimo/máximo da taxa durante o burst.
BURST_MULT_MIN=10
BURST_MULT_MAX=80
# Fator de inflação de valor das transações sintéticas.
BURST_VALUE_FACTOR=50
# BURST_SEED vazio = aleatório (demo). Defina um número p/ reprodutibilidade.
BURST_SEED=

# --- AML (limiares) ---
# Janela do padrão circular A->B->C->A (10 min) e valor agregado mínimo (cents).
AML_CYCLE_WINDOW_S=600
AML_CYCLE_MIN_CENTS=100000000
# Velocidade: nº de transações e janela (s).
AML_VELOCITY_N=15
AML_VELOCITY_WINDOW_S=60
# Structuring: nº de transferências, janela (s) e limiar "just-below" (cents).
AML_STRUCT_N=8
AML_STRUCT_WINDOW_S=3600
AML_STRUCT_BELOW_CENTS=1000000

# --- Infra (não precisa mudar para rodar local) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
POSTGRES_USER=pix
POSTGRES_PASSWORD=pix
POSTGRES_DB=pix
