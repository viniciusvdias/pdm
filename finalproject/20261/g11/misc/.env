# --------------------------------------------------------------------------- #
# Variaveis de ambiente do docker-compose
# Ajuste estes valores para os experimentos de benchmark.
# --------------------------------------------------------------------------- #

# --- Imagens (tags pinadas para reprodutibilidade) ---
KAFKA_IMAGE=apache/kafka:3.9.0
# Bitnami migrou seu catalogo publico para `bitnamilegacy` em ago/2025; a tag
# `bitnami/spark:3.5.4` deixou de existir no Docker Hub. `bitnamilegacy/spark`
# e a MESMA imagem (mesmos env vars SPARK_MODE/SPARK_MASTER_URL), so movida de org.
SPARK_IMAGE=bitnamilegacy/spark:3.5.4

# --- Recursos de cada Spark Worker ---
# Cenario A (variar cores do executor) ajusta isto + o spark-submit.
SPARK_WORKER_CORES=4
SPARK_WORKER_MEMORY=4G

# --- Cluster ID do KRaft ---
# Exigido pela imagem apache/kafka em modo KRaft. Mantenha estavel: trocar este
# valor invalida o volume kafka-data existente (exigiria `down -v`).
KAFKA_CLUSTER_ID=6hDDbsLnSTen3HTYifOUNA

# --- Topico Kafka ---
KAFKA_TOPIC=taxi_trips_stream
# Numero de particoes do topico: defina >= numero total de cores dos workers
# para permitir consumo paralelo pelo Spark (cada particao = 1 task de leitura).
KAFKA_TOPIC_PARTITIONS=12
