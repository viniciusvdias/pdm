# Variáveis de ambiente configuráveis via -e no docker compose run
# Copie este arquivo para .env e ajuste conforme necessário

# ── Caminhos dentro do container ──────────────────────────────────────────────
DATASET_PATH=/datasets/taxi_1gb.csv
RESULTS_PATH=/results/metrics_1gb.csv

# ── Benchmark Multiprocessing (benchmark service) ─────────────────────────────
WORKERS_LIST=1,2,4,8,16
N_REPS=3
CHUNK_SIZE=500000

# ── Benchmark Apache Spark (spark-benchmark service) ──────────────────────────
CORES_LIST=1,2,4,8,16
DRIVER_MEM=4g

# ── Informações do hardware (usadas no relatório HTML) ────────────────────────
CPU_INFO=AMD Ryzen 7 8700G
HOST_CORES=16
